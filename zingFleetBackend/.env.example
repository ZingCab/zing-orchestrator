# ===========================================
# ZingCab Fleet Backend — copy to .env and fill values (never commit .env)
# ===========================================

# Supabase — Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URL (optional — for psql migrations only)
SUPABASE_DB_URL=

# Optional: override Savaari booking API base URL (default is in routes/savaari.js)
# SAVAARI_BOOKING_API_URL=https://vendor.savaari.com/vendor/api/booking/v1/booking.php

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated origins (no spaces). Code also allows localhost and zing-fleet.vercel.app by default.
# FRONTEND_URL=

# Admin PIN for POST /api/auth/login
ADMIN_PIN=1234

# Savari bot alerts (optional — each is a no-op if unset)
# ntfy.sh: install the app, subscribe to this topic, get a loud push for
# bid placed / bid failed / feed trouble / dispatch reminders.
# NTFY_TOPIC=zingcab-savari-alerts-CHANGE-ME
# NTFY_SERVER=https://ntfy.sh

# healthchecks.io: create a free check, paste its ping URL here. The
# scheduler pings it every tick; a missed ping = bot-is-down alert on your phone.
# HEALTHCHECKS_URL=https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
